{
  "name": "desktop-app",
  "version": "1.0.4",
  "description": "DeskTime Pro Electron App",
  "main": "main.js",
  "scripts": {
    "start": "electron ."
  },
  "dependencies": {
    "axios": "^1.4.0",
    "form-data": "^4.0.0",
    "screenshot-desktop": "^1.12.7"
  },
  "devDependencies": {
    "electron": "^25.3.0",
    "electron-builder": "^26.15.3",
    "jimp": "^0.16.13",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.desktimepro.app",
    "productName": "DeskTime Pro",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "uninstallDisplayName": "DeskTime Pro",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DeskTime Pro"
    },
    "files": [
      "main.js",
      "preload.js",
      "getActiveWindow.js",
      "frontend-dist/**/*",
      "node_modules/**/*"
    ]
  }
}
